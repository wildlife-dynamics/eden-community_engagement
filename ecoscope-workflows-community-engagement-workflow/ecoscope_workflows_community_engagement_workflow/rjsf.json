    "Choropleth Setting": {
      "type": "object",
      "description": "Number of meetings per location polygon (e.g. adjudication areas, chiefdoms, forest clusters).",
      "ecoscope:task_group": true,
      "properties": {
        "choropleth_colormap": {
          "additionalProperties": false,
          "properties": {
            "colormap": {
              "default": "Blues",
              "title": "Colormap",
              "type": "string",
              "description": "Sequential matplotlib colormap name.",
              "oneOf": [
                {
                  "const": "Blues",
                  "title": "Blues"
                },
                {
                  "const": "Greens",
                  "title": "Greens"
                },
                {
                  "const": "Oranges",
                  "title": "Oranges"
                },
                {
                  "const": "Purples",
                  "title": "Purples"
                },
                {
                  "const": "Reds",
                  "title": "Reds"
                },
                {
                  "const": "Greys",
                  "title": "Greys"
                },
                {
                  "const": "YlOrRd",
                  "title": "Yellow-Orange-Red"
                },
                {
                  "const": "YlOrBr",
                  "title": "Yellow-Orange-Brown"
                },
                {
                  "const": "YlGnBu",
                  "title": "Yellow-Green-Blue"
                },
                {
                  "const": "YlGn",
                  "title": "Yellow-Green"
                },
                {
                  "const": "BuPu",
                  "title": "Blue-Purple"
                },
                {
                  "const": "BuGn",
                  "title": "Blue-Green"
                },
                {
                  "const": "GnBu",
                  "title": "Green-Blue"
                },
                {
                  "const": "OrRd",
                  "title": "Orange-Red"
                },
                {
                  "const": "PuRd",
                  "title": "Purple-Red"
                },
                {
                  "const": "PuBu",
                  "title": "Purple-Blue"
                },
                {
                  "const": "PuBuGn",
                  "title": "Purple-Blue-Green"
                },
                {
                  "const": "RdPu",
                  "title": "Red-Purple"
                },
                {
                  "const": "viridis",
                  "title": "Viridis"
                },
                {
                  "const": "plasma",
                  "title": "Plasma"
                },
                {
                  "const": "magma",
                  "title": "Magma"
                },
                {
                  "const": "cividis",
                  "title": "Cividis"
                }
              ]
            },
            "max_classes": {
              "default": 5,
              "title": "Max Classes",
              "type": "integer",
              "description": "Maximum number of colour classes for the choropleth (Natural Breaks). Automatically reduced if fewer unique values exist in the data."
            },
            "colormap_min": {
              "default": 0.15,
              "maximum": 1.0,
              "minimum": 0.0,
              "title": "Colormap Min",
              "type": "number",
              "description": "Start of the colormap range (0\u20131). Increase to skip the lightest shades."
            },
            "colormap_max": {
              "default": 0.72,
              "maximum": 1.0,
              "minimum": 0.0,
              "title": "Colormap Max",
              "type": "number",
              "description": "End of the colormap range (0\u20131). Decrease to avoid the darkest shades."
            }
          },
          "required": [],
          "type": "object",
          "title": ""
        }
      }
    },
    "choropleth_count_layer": {
      "additionalProperties": false,
      "properties": {
        "layer_style": {
          "allOf": [
            {
              "$ref": "#/$defs/TextLayerStyle"
            }
          ],
          "default": {
            "auto_highlight": false,
            "opacity": 1,
            "pickable": true,
            "get_position": "geometry.coordinates",
            "get_text": "label",
            "get_color": null,
            "get_background_color": null,
            "get_border_color": null,
            "get_border_width": null,
            "get_size": 12,
            "get_angle": null,
            "background_border_radius": null,
            "background_padding": null,
            "billboard": false,
            "background": false,
            "size_scale": 1,
            "size_units": "pixels",
            "size_min_pixels": 0,
            "size_max_pixels": null,
            "font_family": "Monaco, monospace",
            "font_weight": null,
            "line_height": null,
            "outline_width": null,
            "outline_color": null,
            "word_break": "break-word",
            "max_width": null,
            "get_text_anchor": "middle",
            "get_alignment_baseline": "center",
            "get_pixel_offset": [
              0,
              10
            ]
          },
          "title": "Layer Style",
          "description": "Style arguments for the layer.",
          "ecoscope:advanced": true,
          "properties": {
            "get_text": {
              "type": "string",
              "title": "Get Text",
              "default": "label",
              "description": "Column or expression providing the label text."
            },
            "background": {
              "type": "boolean",
              "title": "Background",
              "default": false,
              "description": "Draw a background box behind the text."
            },
            "get_pixel_offset": {
              "type": "array",
              "items": {
                "type": "number"
              },
              "title": "Get Pixel Offset",
              "default": [
                0,
                10
              ],
              "description": "Offset of the text label, in pixels, relative to its anchor point."
            },
            "get_size": {
              "anyOf": [
                {
                  "type": "number",
                  "default": 12,
                  "title": "Get Size"
                }
              ],
              "default": 12,
              "title": "Get Size",
              "description": "Font size of the meeting count labels, in pixels."
            },
            "auto_highlight": {
              "type": "boolean",
              "title": "Auto Highlight",
              "default": false,
              "description": "Enable automatic highlighting when hovering over a label."
            },
            "opacity": {
              "type": "number",
              "title": "Opacity",
              "default": 1,
              "description": "Transparency of the meeting count labels, from 0 (invisible) to 1 (fully opaque)."
            },
            "word_break": {
              "type": "string",
              "enum": [
                "break-word",
                "break-all"
              ],
              "title": "Word Break",
              "default": "break-word",
              "description": "How label text wraps when it exceeds Max Width."
            }
          }
        }
      },
      "type": "object",
      "required": [],
      "title": "Count Layer"
    },
    "choropleth_view_state": {
      "additionalProperties": false,
      "properties": {
        "padding": {
          "default": 0.2,
          "exclusiveMaximum": 1.0,
          "minimum": 0.0,
          "title": "Padding",
          "type": "number",
          "description": "Viewport padding fraction (0\u20131). Fraction of each viewport edge reserved as margin.",
          "ecoscope:advanced": true
        },
        "viewport_width": {
          "default": 2560,
          "title": "Viewport Width",
          "type": "integer",
          "description": "Width of the map's viewport, in pixels. Should match Screenshot Setting's Width for the sharpest result."
