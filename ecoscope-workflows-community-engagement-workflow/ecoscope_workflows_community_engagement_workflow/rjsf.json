        "viewport_height": {
          "default": 1440,
          "title": "Viewport Height",
          "type": "integer",
          "description": "Height of the map's viewport, in pixels. Should match Screenshot Setting's Height for the sharpest result."
        }
      },
      "required": [],
      "type": "object",
      "title": "Choropleth View State"
    },
    "choropleth_png": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "allOf": [
            {
              "$ref": "#/$defs/ScreenshotConfig"
            }
          ],
          "default": {
            "width": 1280,
            "height": 720,
            "full_page": true,
            "device_scale_factor": 2.0,
            "wait_for_timeout": 30000,
            "timeout": 0,
            "max_concurrent_pages": 5,
            "serve_local_files": false
          },
          "title": "Config",
          "description": "The screenshot configuration",
          "properties": {
            "device_scale_factor": {
              "type": "number",
              "title": "Scale Factor",
              "default": 2.0,
              "description": "Rendering scale factor for the screenshot. Higher values produce a sharper image."
            },
            "wait_for_timeout": {
              "type": "integer",
              "title": "Wait Time (ms)",
              "default": 30000,
              "description": "Forced wait time (ms) after network idle before taking the screenshot."
            },
            "width": {
              "type": "integer",
              "title": "Width",
              "default": 2560,
              "description": "Screenshot width, in pixels."
            },
            "height": {
              "type": "integer",
              "title": "Height",
              "default": 1440,
              "description": "Screenshot height, in pixels."
            },
            "full_page": {
              "type": "boolean",
              "title": "Full Page",
              "default": false,
              "description": "Capture the full scrollable page instead of just the visible viewport."
            },
            "timeout": {
              "type": "integer",
              "title": "Timeout",
              "default": 0,
              "description": "Playwright navigation/screenshot timeout in ms. 0 disables timeouts."
            },
            "max_concurrent_pages": {
              "type": "integer",
              "title": "Max Concurrent Pages",
              "default": 5,
              "description": "Maximum number of pages open at once when batching."
            },
            "serve_local_files": {
              "type": "boolean",
              "title": "Serve Local Files",
              "default": false,
              "description": "Start a local HTTP server serving from the HTML file's directory, to avoid CORS restrictions when deck.gl fetches local files."
            }
          },
          "ecoscope:advanced": true
        }
      },
      "required": [],
      "type": "object",
      "title": "Screenshot Setting"
    },
    "Community Report": {
      "type": "object",
      "description": "Generates the community engagement report as a Word document, one per group.",
      "ecoscope:task_group": true,
      "properties": {
        "generate_report": {
          "additionalProperties": false,
          "properties": {
            "template_path": {
              "title": "Template Path",
              "type": "string",
              "description": "Absolute path to the .docx Jinja2 template file.",
              "default": "https://raw.githubusercontent.com/wildlife-dynamics/eden-community_engagement/main/resources/templates/community_engagement_report_template.docx"
            }
          },
          "required": [
            "template_path"
          ],
          "type": "object",
          "title": ""
        }
      }
    }
